*.jks
*.keystore
*.pk8
*.p12
key.properties

# --- IDE - IntelliJ / Android Studio ---
.idea/
*.iml
*.iws
.project
.settings/
.classpath

# --- Sistema Operacional ---
Thumbs.db
.DS_Store

# --- Local Properties (Contém o caminho do SDK local) ---
local.properties
